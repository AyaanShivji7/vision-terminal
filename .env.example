# Vision Terminal — environment contract.
# Copy to .env.local and fill in real values.
# See README.md for details on each variable.

# --- Required ---------------------------------------------------------------

# Neon Postgres connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Clerk auth
CLERK_SECRET_KEY="sk_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."

# OpenAI (gpt-4o-mini for chat + daily top picks generator)
OPENAI_API_KEY="sk-..."

# Finnhub (quotes, candles, news, symbol search). Free tier = 60 req/min.
FINNHUB_API_KEY=""

# Base URL of the deployed app. In production, set to your Vercel URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret the Vercel cron must send in Authorization: Bearer <value>
CRON_SECRET=""

# --- Admin gating (at least one) --------------------------------------------

# Comma-separated Clerk user IDs allowed to call /api/admin/* and
# /api/signals/refresh. Used alongside (or instead of) Clerk
# publicMetadata.role === "admin".
ADMIN_USER_IDS=""

# --- Optional: SnapTrade brokerage linking ----------------------------------

SNAPTRADE_CLIENT_ID=""
SNAPTRADE_CONSUMER_KEY=""
